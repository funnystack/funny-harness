{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run test --silent 2>&1 | tail -5; exit 0"
          },
          {
            "type": "command",
            "command": "mvn clean test>&1 | tail -5; exit 0"
          }
        ]
      }
    ]
  }
}